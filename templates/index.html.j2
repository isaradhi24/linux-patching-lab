<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ansible Node | {{ ansible_hostname }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --debian: #D70A53; --redhat: #CC0000; --suse: #73BA25;
            --accent: {{ '--debian' if ansible_os_family == 'Debian' else '--redhat' if ansible_os_family == 'RedHat' else '--suse' }};
        }
        body { 
            font-family: 'Inter', sans-serif; margin: 0; display: flex; 
            align-items: center; justify-content: center; height: 100vh;
            background: radial-gradient(circle at top left, #1e293b, #0f172a); color: #f8fafc;
        }
        .card { 
            background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);
            padding: 2rem; border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.1);
            border-top: 5px solid var(--accent); width: 400px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .status-container { display: flex; align-items: center; margin-bottom: 1rem; }
        .pulse {
            width: 12px; height: 12px; background: var(--accent); border-radius: 50%;
            margin-right: 12px; box-shadow: 0 0 0 rgba(255, 255, 255, 0.4);
            animation: pulse-animation 2s infinite;
        }
        @keyframes pulse-animation {
            0% { box-shadow: 0 0 0 0 var(--accent); }
            70% { box-shadow: 0 0 0 10px rgba(0, 0, 0, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 0, 0, 0); }
        }
        h1 { margin: 0; font-size: 1.5rem; letter-spacing: -0.025em; }
        .data-row { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
        .label { color: #94a3b8; font-size: 0.875rem; }
        .value { font-weight: 600; font-size: 0.875rem; }
        .footer { margin-top: 1.5rem; font-size: 0.75rem; color: #64748b; text-align: center; }
    </style>
</head>
<body>
    <div class="card">
        <div class="status-container">
            <div class="pulse"></div>
            <h1>{{ ansible_hostname | upper }}</h1>
        </div>
        <div class="data-row">
            <span class="label">OS FAMILY</span>
            <span class="value">{{ ansible_os_family }}</span>
        </div>
        <div class="data-row">
            <span class="label">LAB IP</span>
            <span class="value">{{ ansible_all_ipv4_addresses | select('match', '192.168.57') | first }}</span>
        </div>
        <div class="data-row">
            <span class="label">MEMORY</span>
            <span class="value">{{ ansible_memtotal_mb }} MB</span>
        </div>
        <div class="data-row" style="flex-direction: column; border-bottom: none;">
            <span class="label" style="margin-bottom: 10px; display: block;">PHYSICAL STORAGE (df -h)</span>
            <table style="width: 100%; font-size: 0.7rem; color: #cbd5e1; border-collapse: collapse;">
                <tr style="text-align: left; color: #94a3b8; border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <th style="padding-bottom: 5px;">Mount</th>
                    <th>Used</th>
                    <th>Total</th>
                    <th>%</th>
                </tr>
                {% for mount in ansible_mounts %}
                {# Filter: Only show the main root or disks that aren't virtual tmpfs/snapshots #}
                {% if mount.mount == '/' or (mount.device.startswith('/dev/') and '.snapshots' not in mount.mount) %}
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <td style="padding: 5px 0;">{{ mount.mount }}</td>
                    <td>{{ (mount.size_total - mount.size_available) | filesizeformat }}</td>
                    <td>{{ mount.size_total | filesizeformat }}</td>
                    <td>
                        {% set used_per = ((mount.size_total - mount.size_available) / mount.size_total * 100) | round(0) %}
                        {{ used_per }}%
                    </td>
                </tr>
                {% endif %}
                {% endfor %}
            </table>
        </div>
        <div class="data-row">
            <span class="label">UPTIME</span>
            <span class="value">{{ ansible_uptime_seconds // 3600 }} Hours</span>
        </div>
        <div class="footer">
            Last automated: {{ ansible_date_time.time }}
        </div>
    </div>
</body>
</html>